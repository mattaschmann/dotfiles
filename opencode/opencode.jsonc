{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "git *": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "rm *": "ask"
    }
  },
  "agent": {
    "build": {
      "temperature": 0.15,
      // not sure about this
      // "steps": 40
    },
    "plan": {
      "temperature": 0.4,
      "permission": {
        "edit": {
          ".tasks/**": "allow"
        }
      }
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "us-west-2",
        "profile": "bedrock"
      }
    },
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "local",
      "options": {
        "baseURL": "http://127.0.0.1:9090/v1"
      },
      "models": {
        "Qwen/Qwen2.5-Coder-7B-Instruct-GPTQ-Int4": {
          "name": "local-coder",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "plugin": [
    // "@toninho09/opencode-usage@latest",
    "opencode-model-alias"
  ],
  "disabled_providers": [
    "opencode"
  ]
}
