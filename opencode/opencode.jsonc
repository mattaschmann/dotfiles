{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "git *": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "rm *": "ask",
      "cdk *": "ask",
      "npx cdk *": "ask"
    }
  },
  "agent": {
    "build": {
      "temperature": 0.15
      // not sure about this
      // "steps": 40
    },
    "plan": {
      "temperature": 0.4,
      "permission": {
        "edit": {
          ".tasks/**": "allow"
        }
      }
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "profile": "bedrock"
      }
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://127.0.0.1:9090/v1"
      },
      "models": {
        "local-coder": {
          "name": "local-coder"
        }
      }
    }
  },
  "plugin": [
    // "@toninho09/opencode-usage@latest",
    "opencode-model-alias",
    // "~/workspace/opencode-kirocli-bridge"
  ],
  "disabled_providers": [
    "opencode"
  ]
}
