{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "git *": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "rm *": "ask"
    }
  },
  "agent": {
    "build": {
      "temperature": 0.15,
      // not sure about this
      "steps": 30
    },
    "plan": {
      "temperature": 0.4
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-optimized": {
          "name": "qwen3-coder-optimized"
        }
      }
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://127.0.0.1:9090/v1"
      },
      "models": {
        "Qwen 3 Coder": {
          "name": "Qwen3 Coder",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        }
      }
    }
  },
  "plugin": [
    "openrtk",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
